# Listen on all interfaces within the container so bitcoind can connect
SocksPort 0.0.0.0:9050
DataDirectory /var/lib/tor

# Control port for bitcoind's optional inbound onion service (cookie-authed).
# The tor data volume is mounted read-only into the bitcoin container, whose
# process joins tor's group so it can read the cookie.
ControlPort 0.0.0.0:9051
CookieAuthentication 1
CookieAuthFileGroupReadable 1
DataDirectoryGroupReadable 1
